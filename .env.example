# ════════════════════════════════════════════════════════════════
# EDFLEX QUALIFICATION — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://YOUR_DOMAIN
# Emails autorisés à accéder à la feature Edflex (séparés par virgule)
EDFLEX_ALLOWED_EMAILS=your@email.com

# ── Auth (NextAuth v5) ───────────────────────────────────────────
# Générer avec : openssl rand -base64 32
AUTH_SECRET=your_nextauth_secret_32_chars_minimum

# ── Upstash Redis ────────────────────────────────────────────────
# Créer un compte sur https://upstash.com → nouvelle base Redis
# Utilisé pour : sessions, projets, tokens OAuth, quotas
UPSTASH_REDIS_REST_URL=https://YOUR_INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── Notion OAuth ─────────────────────────────────────────────────
# Créer une intégration OAuth sur https://www.notion.so/my-integrations
# Type : Public integration (OAuth 2.0)
NOTION_CLIENT_ID=your_notion_client_id
NOTION_CLIENT_SECRET=your_notion_client_secret
NOTION_REDIRECT_URI=https://YOUR_DOMAIN/api/auth/notion/callback

# ── Google OAuth + Drive + YouTube ───────────────────────────────
# Créer projet sur https://console.cloud.google.com
# Activer : Google Drive API + YouTube Data API v3
# Configurer OAuth consent screen + credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://YOUR_DOMAIN/api/auth/google/callback
YOUTUBE_API_KEY=your_youtube_api_key

# ── AI — DeepSeek ────────────────────────────────────────────────
# https://platform.deepseek.com → API Keys
# Utilisé pour : qualification OPAD (scorer-llm) + génération livrables
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── AI — Groq ────────────────────────────────────────────────────
# https://console.groq.com → API Keys (gratuit)
# Utilisé pour : modules e-learning, fiches outil, scénarios roleplay
GROQ_API_KEY=your_groq_api_key
GROQ_API_KEY_2=  # optionnel — fallback si limite de débit atteinte
GROQ_MODEL=llama-3.3-70b-versatile

# ── Vercel Blob ───────────────────────────────────────────────────
# Dashboard Vercel → Storage → Blob → Create Store
# Utilisé pour : stockage transcripts sources
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# ── Transcript.com (transcription podcasts) ──────────────────────
# https://app.transcript.com → Settings → API Keys
TRANSCRIPT_API_KEY=your_transcript_api_key
TRANSCRIPT_API_KEY_2=  # optionnel — fallback

# ── n8n (orchestration polling Notion) ───────────────────────────
# Instance n8n auto-hébergée ou https://app.n8n.io
# Le workflow poll Notion toutes les 2 min → POST /api/poll
N8N_URL=https://your-n8n-instance.com
N8N_API_KEY=your_n8n_api_key
N8N_SHARED_SECRET=your_n8n_webhook_secret
