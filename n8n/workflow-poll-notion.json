{
  "name": "Edflex — Poll Notion (URLs, 2min)",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [{ "field": "minutes", "minutesInterval": 2 }] }
      },
      "id": "schedule-notion",
      "name": "Toutes les 2 minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "__APP_BASE_URL__/api/poll",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-n8n-secret", "value": "__N8N_SHARED_SECRET__" }
          ]
        },
        "options": { "timeout": 55000 }
      },
      "id": "http-poll-notion",
      "name": "POST /api/poll",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300]
    }
  ],
  "connections": {
    "Toutes les 2 minutes": {
      "main": [[{ "node": "POST /api/poll", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" },
  "_instructions": {
    "role": "Pipeline URL — déclenche la qualification des sources ajoutées dans la base Notion (Statut 'À qualifier').",
    "APP_BASE_URL": "URL de votre déploiement (ex: https://votre-app.vercel.app)",
    "N8N_SHARED_SECRET": "Même valeur que la variable d'env N8N_SHARED_SECRET de l'app",
    "import": "n8n → Workflows → Import from File → activer le workflow"
  }
}
